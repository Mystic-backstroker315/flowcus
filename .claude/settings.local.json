{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(printf 'n\\\\ny\\\\n')",
      "Bash(printf 'y\\\\nn\\\\n')"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/consi/.claude/statusline-command.sh"
  },
  "spinnerTipsEnabled": true,
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Collecting flows",
      "Parsing IPFIX templates",
      "Compacting generations",
      "Flushing columns",
      "Merging parts",
      "Building bloom filters",
      "Scanning granules",
      "Decoding NetFlow",
      "Pruning partitions",
      "Indexing marks",
      "Checksumming CRCs",
      "Vectorizing filters",
      "Sniffing packets",
      "Crunching octets",
      "Hashing exporters"
    ]
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "Set lengths in IPFIX always include the 4-byte header",
      "Granule size is 8192 rows — marks and blooms index at this boundary",
      "Part names encode generation, time range, and sequence number",
      "CRC32-C checksums protect all binary formats on disk"
    ]
  },
  "promptSuggestionEnabled": true
}
